#! /bin/bash

# We read the number of ensembles from the controlDict
file=$(pwd)"/cwipiConfig"

while read -r name num
do
    if
    [[ $name == "cwipiMembers" ]]; then
     printf -v ensembles "%s\n" "$num"
    fi
done < $file

echo 'The number of ensembles we are dealing with is' $ensembles |sed 's/= //'
cwipiMembers=$(printf "%s" "$ensembles" |sed 's/= //')
# echo $cwipiMembers

# We run the mesh
# blockMesh

rm -rf results postProcessing log
mkdir -p $(pwd)/results

# We create the "processor" folders with all information they need
for ((i=0; i<cwipiMembers; i++));
do 
    mkdir -p $(pwd)/processor$i
    cp -r 0/ processor$i/
    cp -r constant/ processor$i/
    cp -r system/ processor$i/
    # Python default ubuntu version must be python 3 in order to use numpy for random normal distrib
    a=$(python -c "import numpy as np; print('{:.4f}'.format(np.random.normal(0.09, 0.01)))")
    b=$(python -c "import numpy as np; print('{:.4f}'.format(np.random.normal(1.44, 0.03)))")
    c=$(python -c "import numpy as np; print('{:.4f}'.format(np.random.normal(1.92, 0.03)))")
    d=$(python -c "import numpy as np; print('{:.4f}'.format(np.random.normal(1.0, 0.03)))")
    e=$(python -c "import numpy as np; print('{:.4f}'.format(np.random.normal(1.3, 0.03)))")
    echo $a
    echo $b
    echo $c
    echo $d
    echo $e
    sed -i -e "s/Cmu             0.09;/Cmu             $a;/g" processor$i/constant/momentumTransport
    sed -i -e "s/C1              1.44;/C1              $b;/g" processor$i/constant/momentumTransport
    sed -i -e "s/C2              1.92;/C2              $c;/g" processor$i/constant/momentumTransport
    sed -i -e "s/sigmak          1.0;/sigmak          $d;/g" processor$i/constant/momentumTransport
    sed -i -e "s/sigmaEps        1.3;/sigmaEps        $e;/g" processor$i/constant/momentumTransport
done

# We run in parallel with the number of ensembles wished
mpirun -np 1 ./KF_coupling.exe : -np $cwipiMembers cwipiSimpleFoamkEps -parallel | tee log
#mpirun -np 1 ./KF_coupling.exe : -np $cwipiMembers cwipiSimpleFoamkOmegaSST -parallel | tee log
