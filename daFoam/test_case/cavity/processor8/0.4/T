FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0.4";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 300;

boundaryField
{
    movingWall
    {
        type            fixedValue;
        value           uniform 373;
    }
    fixedWalls
    {
        type            zeroGradient;
    }
    frontAndBack
    {
        type            empty;
    }
    procBoundary8to4
    {
        type            processor;
        value           uniform 300;
    }
    procBoundary8to5
    {
        type            processor;
        value           uniform 300;
    }
    procBoundary8to7
    {
        type            processor;
        value           uniform 300;
    }
}


