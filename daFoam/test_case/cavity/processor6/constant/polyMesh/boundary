FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       polyBoundaryMesh;
    location    "constant/polyMesh";
    object      boundary;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

5
(
    movingWall
    {
        type            wall;
        inGroups        1(wall);
        nFaces          6;
        startFace       76;
    }
    fixedWalls
    {
        type            wall;
        inGroups        1(wall);
        nFaces          8;
        startFace       82;
    }
    frontAndBack
    {
        type            empty;
        inGroups        1(empty);
        nFaces          90;
        startFace       90;
    }
    procBoundary6to3
    {
        type            processor;
        inGroups        1(processor);
        nFaces          7;
        startFace       180;
        matchTolerance  0.0001;
        transform       unknown;
        myProcNo        6;
        neighbProcNo    3;
    }
    procBoundary6to7
    {
        type            processor;
        inGroups        1(processor);
        nFaces          7;
        startFace       187;
        matchTolerance  0.0001;
        transform       unknown;
        myProcNo        6;
        neighbProcNo    7;
    }
)

