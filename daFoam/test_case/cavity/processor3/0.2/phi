FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       surfaceScalarField;
    location    "0.2";
    object      phi;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 3 -1 0 0 0 0];

oriented        oriented;

internalField   uniform 0;

boundaryField
{
    movingWall
    {
        type            calculated;
        value           nonuniform List<scalar> 0();
    }
    fixedWalls
    {
        type            calculated;
        value           uniform 0;
    }
    frontAndBack
    {
        type            empty;
        value           nonuniform List<scalar> 0();
    }
    procBoundary3to0
    {
        type            processor;
        value           uniform 0;
    }
    procBoundary3to4
    {
        type            processor;
        value           uniform 0;
    }
    procBoundary3to6
    {
        type            processor;
        value           uniform 0;
    }
    procBoundary3to7
    {
        type            processor;
        value           uniform 0;
    }
}


