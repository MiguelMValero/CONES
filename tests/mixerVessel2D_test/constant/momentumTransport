FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant";
    object      momentumTransport;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

simulationType RAS;

RAS
{
    model           kEpsilon;

    turbulence      on;

    printCoeffs     on;
    
    // These are the values of the k-epsilon model by default
    Cmu             0.15;
    C1              1.2;
    C2              1.6;
    C3              0.0;
    sigmak          1.3;
    sigmaEps        1.0;
    
    // These are the targeted values
    /*Cmu 	    0.09;
    C1		    1.44;
    C2		    1.92;
    C3		    0.0; // This is not a constant of k-epsilon, so we leave the same value as by default
    sigmak	    1.0;
    sigmaEps	    1.3;*/	
}
}

